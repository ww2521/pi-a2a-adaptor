{
  "name": "pi-a2a-adaptor",
  "version": "1.0.1",
  "description": "A2A extension for Pi — `pi install npm:pi-a2a-adaptor`, then `/a2a-send` by name, URL, or agent number",
  "type": "module",
  "main": "src/index.js",
  "keywords": [
    "pi-package",
    "a2a",
    "agent2agent",
    "agent-protocol",
    "pi-extension"
  ],
  "files": [
    "src",
    "pi-extension",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./pi-extension/index.ts"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
